# --- Chat (pick one) ---
# GROQ_API_KEY=your-groq-key
# OPENAI_API_KEY=your-openai-key

# --- Embeddings (pick one) ---
# HUGGINGFACE_TOKEN=your-hf-token
# OPENAI_API_KEY=your-openai-key

# --- Vector DB: Zilliz Cloud (no Docker) ---
# Get cluster endpoint and API key from https://cloud.zilliz.com
# ZILLIZ_URI=
# ZILLIZ_API_KEY=

# Or use username + password (Zilliz accepts token as "username:password"):
# MILVUS_USER=your-username
# MILVUS_PASSWORD=your-password
# (ZILLIZ_URI still required)

# --- Vector DB: Local Milvus (Docker) ---
# MILVUS_URI=http://localhost:19532
# MILVUS_TOKEN=

# Collection and dimensions: the app creates the RAG collection automatically.
# Dimensions are 384 (Hugging Face) or 1536 (OpenAI) based on your embedding config.
# Optional: override the default collection name.
# RAG_COLLECTION_NAME=youtube_vieos_collection

# RAG retrieval: fetch this many candidates, rerank with cross-encoder, then use top RAG_TOP_K in context.
# RAG_TOP_K_RETRIEVE=20
# RAG_TOP_K=5
# RAG_SIMILARITY_THRESHOLD=0.5

# If your Zilliz collection uses different field names (e.g. youtube_creator_collection):
# RAG_COLLECTION_NAME=youtube_creator_collection
# RAG_ID_FIELD=primary_key
# RAG_TEXT_FIELD=text
# RAG_VECTOR_FIELD=vector
# RAG_CHANNEL_NAME_MAX_LENGTH=128
